{
  "name": "jellyfin-payment-portal",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace web run dev",
    "dev:api": "npm --workspace api run dev",
    "build": "npm --workspace api run build && npm --workspace web run build",
    "test": "npm --workspace api test",
    "lint": "npm --workspace web run lint && npm --workspace api run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.4"
  }
}
