SHOP_NAME=<<< SHOP_NAME >>>
SHOP_DISCORD_URL=<<< DISCORD_INVITE_URL >>>

NOWPAYMENTS_API_KEY=<<< HIER EINFÜGEN - dein API-Key fehlt aktuell >>>
# Required: without this the IPN webhook is rejected (no auto-activation after payment).
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# Azteco is disabled by default (mock mode would accept any code). Set AZTECO_ENABLED=true
# only once the real reseller adapter is wired up. Affects both the UI tab and the API.
AZTECO_ENABLED=false
AZTECO_CLIENT_MODE=mock
AZTECO_RESELLER_API_BASE=
AZTECO_RESELLER_API_KEY=
AZTECO_RECEIVE_ADDRESS=

# jfa-go already runs in its own container on this host. The API reaches it via the host
# gateway (works if jfa-go publishes port 8056). Alternatively attach the api service to
# jfa-go's docker network and use http://<jfa-go-container-name>:8056.
# It has no static API key: provide admin credentials, the API logs in to get a token.
JFA_GO_BASE_URL=http://host.docker.internal:8056
JFA_GO_USER=
JFA_GO_PASSWORD=

JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=

# Plex is disabled by default. Set PLEX_ENABLED=true to show it in the UI and enable invites.
PLEX_ENABLED=false
PLEX_TOKEN=
PLEX_SERVER_NAME=

PUBLIC_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:4000
# Optional: set a strong DB password for new deployments (compose picks it up).
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/payment_portal
REDIS_URL=redis://redis:6379
